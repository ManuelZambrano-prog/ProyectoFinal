body {
    font-family: 'Segoe UI', sans-serif;
    margin: 20px;
    background-color: #ffffff;
    color: #1f2532;
}

h1 {
    color: #1e40af;
}

nav a {
    margin-right: 10px;
    text-decoration: none;
    color: #374151;
}

nav a:hover {
    text-decoration: underline;
}

.btn {
    display: inline-block;
    padding: 8px 16px;
    margin: 5px 0;
    color: #ffffff;
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 500;
    transition: background 0.3s, transform 0.2s;
    background-color: #1e40af;
    border: 1px solid #1e40af;
}

.btn:hover {
    background-color: #1e3a8a;
    transform: translateY(-2px);
}

.primary {
    background-color: #1e40af;
    border-color: #1e40af;
}

.primary:hover {
    background-color: #1e3a8a;
}

.delete {
    background-color: #dc2626;
    border-color: #dc2626;
}

.delete:hover {
    background-color: #b91c1c;
}

.item{
    border: 1px solid #e2e8f0;
    padding: 10px;
    margin-bottom: 10px;
}

/* Overlay de carga */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(2px);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* Spinner (rueda) */
.loader {
  width: 48px;
  height: 48px;
  border: 4px solid #e2e8f0;
  border-top-color: #1e40af;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Estado de "cargando" para el botón */
.btn.loading {
  opacity: 0.8;
  pointer-events: none;
}

/* (Opcional) Efecto de punticos en texto "Buscando…" */
@keyframes dots {
  0% { content: ""; }
  33% { content: "."; }
  66% { content: ".."; }
  100% { content: "..."; }
}
.btn.loading[data-loading-label]::after {
  content: attr(data-loading-label);
  margin-left: 6px;
  animation: dots 1.2s steps(3, end) infinite;
}

/* Dashboard styling */
.dashboard-header {
    margin-bottom: 24px;
}

.eyebrow {
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 8px;
}

.subtitle {
    color: #5b6370;
    max-width: 760px;
    line-height: 1.6;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
}

.stat-card,
.card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    box-shadow: 0 16px 40px rgba(30, 64, 175, 0.05);
    padding: 22px;
}

.stat-title {
    color: #6b7280;
    font-size: 0.95rem;
    margin-bottom: 10px;
}

.stat-value {
    font-size: 2.4rem;
    font-weight: 700;
    color: #1e40af;
}

.dashboard-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 2fr 1.2fr;
    margin-bottom: 24px;
}

.card-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
}

.card-header h2 {
    margin: 0 0 6px;
    font-size: 1.35rem;
    color: #1f2532;
}

.card-header p {
    margin: 0;
    color: #6b7280;
}

.table-wrapper {
    overflow-x: auto;
}

.table-dashboard {
    width: 100%;
    border-collapse: collapse;
    min-width: 720px;
}

.table-dashboard th,
.table-dashboard td {
    text-align: left;
    padding: 14px 16px;
    border-bottom: 1px solid #e5e7eb;
}

.table-dashboard th {
    color: #374151;
    font-weight: 600;
    font-size: 0.95rem;
}

.table-dashboard tbody tr:hover {
    background: #f9fafb;
}

.form-grid {
    display: grid;
    gap: 16px;
}

.form-row {
    display: grid;
    gap: 8px;
}

.form-row label {
    font-weight: 600;
    color: #374151;
}

.form-row input,
.form-row select,
.form-row textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #d1d5db;
    border-radius: 14px;
    background: #fafbfc;
    color: #1f2532;
    font-size: 0.98rem;
}

.form-row input:focus,
.form-row select:focus,
.form-row textarea:focus {
    outline: none;
    border-color: #1e40af;
    box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
}

.alert {
    padding: 14px 18px;
    border-radius: 14px;
    border: 1px solid transparent;
    font-weight: 600;
}

.alert.success {
    color: #065f46;
    background: #ecfdf5;
    border-color: #d1fae5;
}

.alert.info {
    color: #1e40af;
    background: #eff6ff;
    border-color: #bfdbfe;
}

.full-width {
    grid-column: 1 / -1;
}

@media (max-width: 1024px) {
    .stats-grid,
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}
